 başında bir akşam — Bolu Dağı eteklerinde mangal","fill":true,"className":"object-cover grayscale-[35%] sepia-[8%] contrast-[1.05] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-700","sizes":"(max-width: 640px) 100vw, 50vw"}]}],["$","div",null,{"className":"flex items-center gap-3 mb-3 font-mono text-[10px] uppercase tracking-[0.16em] sm:tracking-[0.18em]","children":[["$","span",null,{"className":"text-ember font-semibold","children":"Saha Notları"}],["$","span",null,{"className":"w-4 h-px bg-rule"}],["$","span",null,{"className":"text-ink-muted","children":"3 dk"}]]}],["$","h3",null,{"className":"font-display text-xl sm:text-2xl lg:text-[26px] text-ink font-bold leading-tight group-hover:text-ember transition-colors","children":"Bir Cumartesi Gecesi: Köroğlu Eteklerinden Notlar"}]]}]]}]]}]}]
