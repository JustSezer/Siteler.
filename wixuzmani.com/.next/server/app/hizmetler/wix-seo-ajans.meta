{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/hizmetler/layout,_N_T_/hizmetler/[slug]/layout,_N_T_/hizmetler/[slug]/page,_N_T_/hizmetler/wix-seo-ajans"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/hizmetler/$d$slug/__PAGE__",
    "/hizmetler/$d$slug",
    "/hizmetler",
    "/_index",
    "/_head"
  ]
}